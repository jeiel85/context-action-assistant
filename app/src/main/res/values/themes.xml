<resources>
    <!-- Platform theme: Compose Material3 handles all styling.
         Using DeviceDefault.NoActionBar avoids extra Material library dependency. -->
    <style name="Theme.ContextActionAssistant" parent="android:Theme.DeviceDefault.NoActionBar">
        <!-- No title, fullscreen for overlay compatibility -->
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsTranslucent">true</item>
    </style>
</resources>
